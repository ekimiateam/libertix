<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">
    
    <!-- MainWindow -->
    <system:String x:Key="Welcome">¡Bienvenido a Libertix!</system:String>
    <system:String x:Key="Subtitle">Un instalador de Linux simple y moderno</system:String>
    <system:String x:Key="GetStarted">Comenzar</system:String>
    <system:String x:Key="Language">Idioma</system:String>

    <!-- ChooseDistro -->
    <system:String x:Key="ChooseDistroTitle">Elija su versión de Linux</system:String>
    
    <!-- Distro Descriptions -->
    <system:String x:Key="ZorinDescription">Un sistema operativo potente, seguro y fácil de usar, diseñado para todos.</system:String>
    <system:String x:Key="UbuntuDescription">Rápido, gratuito y lleno de nuevas características. Ubuntu es el sistema Linux preferido en el mundo.</system:String>

    <!-- ResizeDisk -->
    <system:String x:Key="ResizeDiskTitle">Redimensiona tu disco</system:String>
    <system:String x:Key="Windows">Windows</system:String>
    <system:String x:Key="Linux">Linux</system:String>
    <system:String x:Key="NotEnoughSpace">Espacio insuficiente</system:String>
    <system:String x:Key="FreeUpSpace">Tu sistema necesita más espacio libre para instalar Linux. Libera algo de espacio e inténtalo de nuevo.</system:String>
    <system:String x:Key="OpenDiskCleanup">Abrir limpieza de disco</system:String>

    <!-- AccountCreation -->
    <system:String x:Key="AccountCreationTitle">Crea tu cuenta de Linux</system:String>
    <system:String x:Key="Username">Nombre de usuario</system:String>
    <system:String x:Key="Password">Contraseña</system:String>
    <system:String x:Key="ConfirmPassword">Confirmar contraseña</system:String>
    <system:String x:Key="ComputerName">Nombre del equipo</system:String>

    <!-- Common -->
    <system:String x:Key="Back">Atrás</system:String>
    <system:String x:Key="Next">Siguiente</system:String>
    
    <!-- Errors -->
    <system:String x:Key="DistroLoadError">No se pudo cargar la lista de distribuciones. Por favor, compruebe su conexión a Internet e inténtelo de nuevo.</system:String>

    <!-- Password Validation -->
    <system:String x:Key="PasswordRequired">La contraseña es obligatoria</system:String>
    <system:String x:Key="PasswordTooShort">La contraseña debe tener al menos 4 caracteres</system:String>
    <system:String x:Key="PasswordTooLong">La contraseña debe tener 8 caracteres o menos</system:String>

    <!-- Partition Warning -->
    <system:String x:Key="PartitionWarningTitle">ADVERTENCIA: Configuración de partición no estándar</system:String>
    <system:String x:Key="PartitionWarningMessage">Este instalador NO ha sido probado en esta configuración de particiones. Continuar NO SE RECOMIENDA a menos que sepa EXACTAMENTE lo que está haciendo.</system:String>
    <system:String x:Key="PartitionWarningCheckbox">Entiendo</system:String>

    <!-- Warning Confirmation -->
    <system:String x:Key="WarningTitle">Advertencia</system:String>
    <system:String x:Key="WarningMessage">Está a punto de realizar cambios significativos en las particiones de su disco. Esta operación modificará su disco duro e instalará un sistema de arranque dual junto con Windows.</system:String>
    <system:String x:Key="WarningRisks">RIESGOS:
- Pérdida de datos si la operación falla o se interrumpe
- Posible corrupción de la instalación de Windows existente
- Su computadora puede no arrancar si algo sale mal
- Esta operación NO se puede deshacer fácilmente</system:String>
    <system:String x:Key="WarningRecommendations">RECOMENDACIONES:
- Haga una copia de seguridad de todos sus datos importantes antes de continuar
- Asegúrese de que su portátil esté conectado (no confíe en la batería)
- Tenga un USB de recuperación de Windows listo
- Tenga a alguien con conocimientos técnicos disponible si es necesario
- NO interrumpa el proceso de instalación una vez iniciado</system:String>
    <system:String x:Key="WarningConfirmCheckbox">Entiendo los riesgos y he respaldado mis datos importantes</system:String>
    <system:String x:Key="WarningConfirmButton">Entiendo, Continuar</system:String>

    <!-- Comprobación de compatibilidad -->
    <system:String x:Key="CompatibilityTitle">Comprobación de compatibilidad</system:String>
    <system:String x:Key="CompatibilityDescription">Libertix comprueba la memoria, el firmware y el almacenamiento antes de continuar.</system:String>
    <system:String x:Key="CompatibilityStarting">Iniciando comprobaciones...</system:String>
    <system:String x:Key="CompatibilityRetry">Reintentar</system:String>
    <system:String x:Key="CompatibilityContinue">Continuar</system:String>
    <system:String x:Key="CompatibilityRunning">Comprobando este equipo...</system:String>
    <system:String x:Key="CompatibilityLowMemorySuccess">El equipo es compatible. Se utilizará el modo de memoria reducida.</system:String>
    <system:String x:Key="CompatibilitySuccess">El equipo es compatible con Libertix.</system:String>
    <system:String x:Key="CompatibilityWarningPrefix">ADVERTENCIA: </system:String>
    <system:String x:Key="CompatibilityUnexpectedPrefix">COMPAT_E_UNEXPECTED: </system:String>

    <!-- Uso compartido de archivos -->
    <system:String x:Key="SharingTitle">Uso compartido de archivos</system:String>
    <system:String x:Key="SharingDescription">Elija qué archivos estarán disponibles desde cada sistema.</system:String>
    <system:String x:Key="SharingWindowsToLinuxTitle">Mostrar los archivos de Windows en Mint</system:String>
    <system:String x:Key="SharingWindowsToLinuxDescription">Cada perfil de Windows aparecerá como User_nombre en el gestor de archivos.</system:String>
    <system:String x:Key="SharingLinuxToWindowsTitle">Mostrar los archivos de Linux en Windows (solo lectura)</system:String>
    <system:String x:Key="SharingLinuxToWindowsDescription">Windows podrá consultar los archivos de Linux sin modificar la partición ext4.</system:String>

    <!-- Recuperación del arranque UEFI -->
    <system:String x:Key="UefiFallbackTitle">El arranque UEFI no inició el instalador</system:String>
    <system:String x:Key="UefiFallbackDescription">Windows regresó sin el marcador del sistema live. Libertix conservó una copia local verificada y puede usar la entrada UEFI validada para reiniciar el sistema live.</system:String>
    <system:String x:Key="UefiFallbackChecking">Comprobando el estado de recuperación...</system:String>
    <system:String x:Key="UefiFallbackCancel">Cancelar y restaurar Windows</system:String>
    <system:String x:Key="UefiFallbackUseFirmware">Usar el arranque del firmware</system:String>
    <system:String x:Key="UefiFallbackReboot">Reiniciar</system:String>
    <system:String x:Key="UefiFallbackStateMissing">No se encontró el estado de recuperación UEFI.</system:String>
    <system:String x:Key="UefiFallbackStateIncomplete">El estado de recuperación UEFI está incompleto.</system:String>
    <system:String x:Key="UefiFallbackBootNextFailedLog">BootNext no alcanzó el sistema live. La estrategia de firmware validada está lista.</system:String>
    <system:String x:Key="UefiFallbackReady">Elija si Libertix debe reiniciar mediante la entrada de firmware UEFI.</system:String>
    <system:String x:Key="UefiFallbackLoadFailed">No se pudo cargar la recuperación UEFI.</system:String>
    <system:String x:Key="UefiFallbackErrorPrefix">ERROR: </system:String>
    <system:String x:Key="UefiFallbackPreparingFirmware">Preparando el arranque del firmware UEFI...</system:String>
    <system:String x:Key="UefiFallbackFirmwareFailedFormat">Falló la preparación del arranque del firmware (rc={0}).</system:String>
    <system:String x:Key="UefiFallbackFirmwareReady">El arranque del firmware está preparado. Reinicie para iniciar el sistema live.</system:String>
    <system:String x:Key="UefiFallbackPreparationFailed">Falló la preparación del modo alternativo.</system:String>
    <system:String x:Key="UefiFallbackRestoring">Restaurando el estado UEFI inicial...</system:String>
    <system:String x:Key="UefiFallbackRestoreFailedFormat">Falló la restauración UEFI (rc={0}).</system:String>
    <system:String x:Key="UefiFallbackWindowsRestored">Windows ha sido restaurado. Libertix se cerrará.</system:String>
    <system:String x:Key="UefiFallbackCancelledLog">Transacción UEFI cancelada y archivos temporales programados para su eliminación.</system:String>
    <system:String x:Key="UefiFallbackRestoreFailed">Falló la restauración UEFI.</system:String>
    <system:String x:Key="UefiFallbackTimeoutLog">ERROR: el proceso de recuperación superó el límite de 30 minutos</system:String>

    <!-- Apply Changes -->
    <system:String x:Key="ApplyChangesTitle">Aplicar cambios</system:String>
    <system:String x:Key="ApplyChangesWaiting">Listo para iniciar el particionamiento</system:String>
    <system:String x:Key="ApplyChangesSummary">Resumen de la instalacion</system:String>
    <system:String x:Key="ApplyChangesDistro">Distribucion:</system:String>
    <system:String x:Key="ApplyChangesLinuxSize">Espacio Linux:</system:String>
    <system:String x:Key="ApplyChangesUsername">Nombre de usuario:</system:String>
    <system:String x:Key="ApplyChangesStart">Iniciar instalacion</system:String>
    <system:String x:Key="ApplyChangesStep1">Reduciendo particion de Windows para Linux...</system:String>
    <system:String x:Key="ApplyChangesStep2">Creando particion FAT32 de arranque (Z:)...</system:String>
    <system:String x:Key="ApplyChangesWaitDisk">Esperando actualizacion del disco...</system:String>
    <system:String x:Key="ApplyChangesStep3">Reduciendo particion de Windows para Linux...</system:String>
    <system:String x:Key="ApplyChangesComplete">Particionamiento completado!</system:String>
    <system:String x:Key="ApplyChangesError">Ocurrio un error</system:String>
    <system:String x:Key="ApplyChangesReboot">Reiniciar</system:String>
    <system:String x:Key="ApplyChangesRebootConfirm">El ordenador se reiniciara para completar la instalacion. Continuar?</system:String>
    <system:String x:Key="ApplyChangesCancel">Cancelar la instalacion</system:String>
    <system:String x:Key="ApplyChangesCancelConfirm">Cancelar la instalacion y restaurar Windows? La operacion segura actual se detendra y Libertix ejecutara y verificara la restauracion.</system:String>
    <system:String x:Key="ApplyChangesCancelInProgress">Cancelacion solicitada. Restaurando Windows...</system:String>
    <system:String x:Key="ApplyChangesExpandLogs">Ampliar registros</system:String>
    <system:String x:Key="ApplyChangesLogsTitle">Registros de instalación</system:String>
    <system:String x:Key="ApplyChangesCloseExpandedLogs">Reducir registros</system:String>
    <system:String x:Key="CloseConfirmationTitle">Cerrar Libertix</system:String>
    <system:String x:Key="CloseConfirmationMessage">Realmente desea cerrar Libertix?</system:String>
    <system:String x:Key="TrayInstallTitle">Instalacion de Libertix en curso</system:String>
    <system:String x:Key="TrayInstallMessage">La instalacion sigue ejecutandose. Haga doble clic en el icono de Libertix junto al reloj para volver a abrir la ventana.</system:String>
    <system:String x:Key="PartitionSafetyBlockMessage">La instalación está bloqueada hasta resolver este control de seguridad.</system:String>
</ResourceDictionary>
