<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">
    
    <!-- MainWindow -->
    <system:String x:Key="Welcome">Libertixへようこそ！</system:String>
    <system:String x:Key="Subtitle">シンプルでモダンなLinuxインストーラー</system:String>
    <system:String x:Key="GetStarted">始める</system:String>
    <system:String x:Key="Language">言語</system:String>

    <!-- ChooseDistro -->
    <system:String x:Key="ChooseDistroTitle">お好みのLinuxディストリビューションを選ぶ</system:String>
    
    <!-- Distro Descriptions -->
    <system:String x:Key="ZorinDescription">誰でも使える、安全で使いやすい強力なオペレーティングシステム。</system:String>
    <system:String x:Key="UbuntuDescription">高速、無料、新機能が充実。世界で最も人気のあるLinuxオペレーティングシステム。</system:String>

    <!-- ResizeDisk -->
    <system:String x:Key="ResizeDiskTitle">ディスクのサイズを変更</system:String>
    <system:String x:Key="Windows">Windows</system:String>
    <system:String x:Key="Linux">Linux</system:String>
    <system:String x:Key="NotEnoughSpace">空き領域が不足しています</system:String>
    <system:String x:Key="FreeUpSpace">Linuxをインストールするにはさらに空き領域が必要です。不要なファイルを削除して再試行してください。</system:String>
    <system:String x:Key="OpenDiskCleanup">ディスククリーンアップを開く</system:String>

    <!-- AccountCreation -->
    <system:String x:Key="AccountCreationTitle">Linuxアカウントを作成</system:String>
    <system:String x:Key="Username">ユーザー名</system:String>
    <system:String x:Key="Password">パスワード</system:String>
    <system:String x:Key="ConfirmPassword">パスワードの確認</system:String>
    <system:String x:Key="ComputerName">コンピューター名</system:String>

    <!-- Common -->
    <system:String x:Key="Back">戻る</system:String>
    <system:String x:Key="Next">次へ</system:String>
    
    <!-- Errors -->
    <system:String x:Key="DistroLoadError">ディストリビューションのリストを読み込めませんでした。インターネット接続を確認して、もう一度お試しください。</system:String>

    <!-- Password Validation -->
    <system:String x:Key="PasswordRequired">パスワードは必須です</system:String>
    <system:String x:Key="PasswordTooShort">パスワードは4文字以上必要です</system:String>
    <system:String x:Key="PasswordTooLong">パスワードは8文字以内にしてください</system:String>

    <!-- Partition Warning -->
    <system:String x:Key="PartitionWarningTitle">警告：非標準のパーティション構成</system:String>
    <system:String x:Key="PartitionWarningMessage">このインストーラーはこのパーティション構成でテストされていません。正確に何をしているか理解していない限り、続行は強くお勧めしません。</system:String>
    <system:String x:Key="PartitionWarningCheckbox">理解しました</system:String>

    <!-- Warning Confirmation -->
    <system:String x:Key="WarningTitle">警告</system:String>
    <system:String x:Key="WarningMessage">ディスクパーティションに重大な変更を加えようとしています。この操作はハードドライブを変更し、Windowsと共にデュアルブートシステムをインストールします。</system:String>
    <system:String x:Key="WarningRisks">リスク：
- 操作が失敗または中断された場合のデータ損失
- 既存のWindowsインストールが破損する可能性
- 問題が発生するとコンピューターが起動しなくなる可能性
- この操作は簡単に元に戻すことができません</system:String>
    <system:String x:Key="WarningRecommendations">推奨事項：
- 続行する前にすべての重要なデータをバックアップしてください
- ノートパソコンは電源に接続してください（バッテリーに頼らないでください）
- Windows回復USBを用意してください
- 必要に応じて技術的な知識のある人を近くに用意してください
- インストールプロセスが開始したら中断しないでください</system:String>
    <system:String x:Key="WarningConfirmCheckbox">リスクを理解し、重要なデータをバックアップしました</system:String>
    <system:String x:Key="WarningConfirmButton">理解しました、続行</system:String>

    <!-- 互換性チェック -->
    <system:String x:Key="CompatibilityTitle">互換性チェック</system:String>
    <system:String x:Key="CompatibilityDescription">続行する前に、Libertix がメモリ、ファームウェア、ストレージを確認します。</system:String>
    <system:String x:Key="CompatibilityStarting">チェックを開始しています...</system:String>
    <system:String x:Key="CompatibilityRetry">再試行</system:String>
    <system:String x:Key="CompatibilityContinue">続行</system:String>
    <system:String x:Key="CompatibilityRunning">このコンピューターを確認しています...</system:String>
    <system:String x:Key="CompatibilityLowMemorySuccess">このコンピューターは互換性があります。省メモリモードを使用します。</system:String>
    <system:String x:Key="CompatibilitySuccess">このコンピューターは Libertix と互換性があります。</system:String>
    <system:String x:Key="CompatibilityWarningPrefix">警告: </system:String>
    <system:String x:Key="CompatibilityUnexpectedPrefix">COMPAT_E_UNEXPECTED: </system:String>

    <!-- ファイル共有 -->
    <system:String x:Key="SharingTitle">ファイル共有</system:String>
    <system:String x:Key="SharingDescription">各システムからアクセスできるファイルを選択してください。</system:String>
    <system:String x:Key="SharingWindowsToLinuxTitle">Windows のファイルを Mint に表示</system:String>
    <system:String x:Key="SharingWindowsToLinuxDescription">各 Windows プロファイルはファイルマネージャーに User_名前として表示されます。</system:String>
    <system:String x:Key="SharingLinuxToWindowsTitle">Linux のファイルを Windows に表示（読み取り専用）</system:String>
    <system:String x:Key="SharingLinuxToWindowsDescription">Windows は ext4 パーティションを変更せずに Linux のファイルを参照できます。</system:String>

    <!-- UEFI ブート回復 -->
    <system:String x:Key="UefiFallbackTitle">UEFI ブートでインストーラーを起動できませんでした</system:String>
    <system:String x:Key="UefiFallbackDescription">live のマーカーがないまま Windows に戻りました。Libertix は検証済みのローカルコピーを保持しており、検証済みの UEFI ファームウェアエントリから live を再起動できます。</system:String>
    <system:String x:Key="UefiFallbackChecking">回復状態を確認しています...</system:String>
    <system:String x:Key="UefiFallbackCancel">キャンセルして Windows を復元</system:String>
    <system:String x:Key="UefiFallbackUseFirmware">ファームウェアブートを使用</system:String>
    <system:String x:Key="UefiFallbackReboot">再起動</system:String>
    <system:String x:Key="UefiFallbackStateMissing">UEFI 回復状態が見つかりません。</system:String>
    <system:String x:Key="UefiFallbackStateIncomplete">UEFI 回復状態が不完全です。</system:String>
    <system:String x:Key="UefiFallbackBootNextFailedLog">BootNext は live に到達しませんでした。検証済みのファームウェア方式を使用できます。</system:String>
    <system:String x:Key="UefiFallbackReady">UEFI ファームウェアエントリを使用して Libertix を再起動するか選択してください。</system:String>
    <system:String x:Key="UefiFallbackLoadFailed">UEFI 回復を読み込めません。</system:String>
    <system:String x:Key="UefiFallbackErrorPrefix">エラー: </system:String>
    <system:String x:Key="UefiFallbackPreparingFirmware">UEFI ファームウェアブートを準備しています...</system:String>
    <system:String x:Key="UefiFallbackFirmwareFailedFormat">ファームウェアブートの準備に失敗しました (rc={0})。</system:String>
    <system:String x:Key="UefiFallbackFirmwareReady">ファームウェアブートの準備が完了しました。live を起動するには再起動してください。</system:String>
    <system:String x:Key="UefiFallbackPreparationFailed">フォールバックの準備に失敗しました。</system:String>
    <system:String x:Key="UefiFallbackRestoring">初期 UEFI 状態を復元しています...</system:String>
    <system:String x:Key="UefiFallbackRestoreFailedFormat">UEFI の復元に失敗しました (rc={0})。</system:String>
    <system:String x:Key="UefiFallbackWindowsRestored">Windows を復元しました。Libertix を終了します。</system:String>
    <system:String x:Key="UefiFallbackCancelledLog">UEFI トランザクションをキャンセルし、一時ファイルを削除するよう設定しました。</system:String>
    <system:String x:Key="UefiFallbackRestoreFailed">UEFI の復元に失敗しました。</system:String>
    <system:String x:Key="UefiFallbackTimeoutLog">エラー: 回復処理が 30 分の制限時間を超えました</system:String>

    <!-- Apply Changes -->
    <system:String x:Key="ApplyChangesTitle">変更を適用</system:String>
    <system:String x:Key="ApplyChangesWaiting">パーティション作成の準備完了</system:String>
    <system:String x:Key="ApplyChangesSummary">インストール概要</system:String>
    <system:String x:Key="ApplyChangesDistro">ディストリビューション:</system:String>
    <system:String x:Key="ApplyChangesLinuxSize">Linux領域:</system:String>
    <system:String x:Key="ApplyChangesUsername">ユーザー名:</system:String>
    <system:String x:Key="ApplyChangesStart">インストール開始</system:String>
    <system:String x:Key="ApplyChangesStep1">Linux用にWindowsパーティションを縮小中...</system:String>
    <system:String x:Key="ApplyChangesStep2">FAT32ブートパーティションを作成中（Z:）...</system:String>
    <system:String x:Key="ApplyChangesWaitDisk">ディスク更新を待機中...</system:String>
    <system:String x:Key="ApplyChangesStep3">Linux用にWindowsパーティションを縮小中...</system:String>
    <system:String x:Key="ApplyChangesComplete">パーティション作成完了！</system:String>
    <system:String x:Key="ApplyChangesError">エラーが発生しました</system:String>
    <system:String x:Key="ApplyChangesReboot">再起動</system:String>
    <system:String x:Key="ApplyChangesRebootConfirm">インストールを完了するためにコンピューターを再起動します。続行しますか？</system:String>
    <system:String x:Key="PartitionSafetyBlockMessage">この安全性チェックが解決されるまでインストールはブロックされます。</system:String>
</ResourceDictionary>
