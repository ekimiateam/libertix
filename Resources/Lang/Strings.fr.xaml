<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:system="clr-namespace:System;assembly=mscorlib">
    
    <!-- MainWindow -->
    <system:String x:Key="Welcome">Bienvenue sur Libertix !</system:String>
    <system:String x:Key="Subtitle">Un installateur Linux simple et moderne</system:String>
    <system:String x:Key="GetStarted">Commencer</system:String>
    <system:String x:Key="Language">Langue</system:String>

    <!-- ChooseDistro -->
    <system:String x:Key="ChooseDistroTitle">Choisissez votre version de Linux !</system:String>
    
    <!-- Distro Descriptions -->
    <system:String x:Key="ZorinDescription">Un système d'exploitation puissant, sûr et facile à utiliser, conçu pour tous.</system:String>
    <system:String x:Key="UbuntuDescription">Rapide, gratuit et riche en nouvelles fonctionnalités. Ubuntu est le système Linux le plus apprécié au monde.</system:String>

    <!-- ResizeDisk -->
    <system:String x:Key="ResizeDiskTitle">Redimensionnez votre disque</system:String>
    <system:String x:Key="Windows">Windows</system:String>
    <system:String x:Key="Linux">Linux</system:String>
    <system:String x:Key="NotEnoughSpace">Espace insuffisant</system:String>
    <system:String x:Key="FreeUpSpace">Votre système a besoin de plus d'espace libre pour installer Linux. Veuillez libérer de l'espace et réessayer.</system:String>
    <system:String x:Key="OpenDiskCleanup">Ouvrir le nettoyage de disque</system:String>

    <!-- AccountCreation -->
    <system:String x:Key="AccountCreationTitle">Créez votre compte Linux</system:String>
    <system:String x:Key="Username">Nom d'utilisateur</system:String>
    <system:String x:Key="Password">Mot de passe</system:String>
    <system:String x:Key="ConfirmPassword">Confirmer le mot de passe</system:String>
    <system:String x:Key="ComputerName">Nom de l'ordinateur</system:String>

    <!-- Common -->
    <system:String x:Key="Back">Retour</system:String>
    <system:String x:Key="Next">Suivant</system:String>
    
    <!-- Errors -->
    <system:String x:Key="DistroLoadError">Impossible de charger la liste des distributions. Veuillez vérifier votre connexion Internet et réessayer.</system:String>

    <!-- Password Validation -->
    <system:String x:Key="PasswordRequired">Le mot de passe est requis</system:String>
    <system:String x:Key="PasswordTooShort">Le mot de passe doit contenir au moins 4 caractères</system:String>
    <system:String x:Key="PasswordTooLong">Le mot de passe doit contenir 8 caractères maximum</system:String>

    <!-- Partition Warning -->
    <system:String x:Key="PartitionWarningTitle">ATTENTION : Configuration de partition non standard</system:String>
    <system:String x:Key="PartitionWarningMessage">Cet installateur n'a PAS été testé sur cette configuration de partitions. Continuer est FORTEMENT DÉCONSEILLÉ sauf si vous savez EXACTEMENT ce que vous faites.</system:String>
    <system:String x:Key="PartitionWarningCheckbox">Je comprends</system:String>

    <!-- Warning Confirmation -->
    <system:String x:Key="WarningTitle">Avertissement</system:String>
    <system:String x:Key="WarningMessage">Vous allez effectuer des modifications importantes sur les partitions de votre disque. Cette opération va modifier votre disque dur et installer un système dual-boot aux côtés de Windows.</system:String>
    <system:String x:Key="WarningRisks">RISQUES :
- Perte de données si l'opération échoue ou est interrompue
- Corruption potentielle de l'installation Windows existante
- Votre ordinateur peut ne plus démarrer si quelque chose se passe mal
- Cette opération ne peut PAS être annulée facilement</system:String>
    <system:String x:Key="WarningRecommendations">RECOMMANDATIONS :
- Sauvegardez toutes vos données importantes avant de continuer
- Assurez-vous que votre PC portable est branché (ne comptez pas sur la batterie)
- Ayez une clé USB de récupération Windows prête
- Ayez quelqu'un avec des connaissances techniques disponible si nécessaire
- N'interrompez PAS le processus d'installation une fois lancé</system:String>
    <system:String x:Key="WarningConfirmCheckbox">Je comprends les risques et j'ai sauvegardé mes données importantes</system:String>
    <system:String x:Key="WarningConfirmButton">Je comprends</system:String>

    <!-- Vérification de compatibilité -->
    <system:String x:Key="CompatibilityTitle">Vérification de compatibilité</system:String>
    <system:String x:Key="CompatibilityDescription">Libertix vérifie la mémoire, le firmware et le stockage avant de continuer.</system:String>
    <system:String x:Key="CompatibilityStarting">Démarrage des vérifications...</system:String>
    <system:String x:Key="CompatibilityRetry">Réessayer</system:String>
    <system:String x:Key="CompatibilityContinue">Continuer</system:String>
    <system:String x:Key="CompatibilityRunning">Vérification de la machine en cours...</system:String>
    <system:String x:Key="CompatibilityLowMemorySuccess">Machine compatible. Le mode faible mémoire sera utilisé.</system:String>
    <system:String x:Key="CompatibilitySuccess">Machine compatible avec Libertix.</system:String>
    <system:String x:Key="CompatibilityWarningPrefix">AVERTISSEMENT : </system:String>
    <system:String x:Key="CompatibilityUnexpectedPrefix">COMPAT_E_UNEXPECTED : </system:String>

    <!-- Partage des fichiers -->
    <system:String x:Key="SharingTitle">Partage des fichiers</system:String>
    <system:String x:Key="SharingDescription">Choisissez les fichiers accessibles depuis chaque système.</system:String>
    <system:String x:Key="SharingWindowsToLinuxTitle">Afficher les fichiers Windows dans Mint</system:String>
    <system:String x:Key="SharingWindowsToLinuxDescription">Chaque profil Windows apparaîtra sous le nom User_nom dans le gestionnaire de fichiers.</system:String>
    <system:String x:Key="SharingLinuxToWindowsTitle">Afficher les fichiers Linux dans Windows (lecture seule)</system:String>
    <system:String x:Key="SharingLinuxToWindowsDescription">Windows pourra consulter les fichiers Linux sans pouvoir modifier la partition ext4.</system:String>

    <!-- Reprise du démarrage UEFI -->
    <system:String x:Key="UefiFallbackTitle">Le démarrage UEFI n'a pas lancé l'installateur</system:String>
    <system:String x:Key="UefiFallbackDescription">Windows est revenu sans marqueur du live. Libertix a conservé une copie locale vérifiée et peut utiliser l'entrée firmware UEFI validée pour relancer le live.</system:String>
    <system:String x:Key="UefiFallbackChecking">Vérification de l'état de reprise...</system:String>
    <system:String x:Key="UefiFallbackCancel">Annuler et restaurer Windows</system:String>
    <system:String x:Key="UefiFallbackUseFirmware">Utiliser le démarrage firmware</system:String>
    <system:String x:Key="UefiFallbackReboot">Redémarrer</system:String>
    <system:String x:Key="UefiFallbackStateMissing">État de reprise UEFI introuvable.</system:String>
    <system:String x:Key="UefiFallbackStateIncomplete">État de reprise UEFI incomplet.</system:String>
    <system:String x:Key="UefiFallbackBootNextFailedLog">BootNext n'a pas atteint le live. La stratégie firmware validée est prête.</system:String>
    <system:String x:Key="UefiFallbackReady">Choisissez si Libertix doit relancer avec l'entrée firmware UEFI.</system:String>
    <system:String x:Key="UefiFallbackLoadFailed">Impossible de charger la reprise UEFI.</system:String>
    <system:String x:Key="UefiFallbackErrorPrefix">ERREUR : </system:String>
    <system:String x:Key="UefiFallbackPreparingFirmware">Préparation du démarrage firmware UEFI...</system:String>
    <system:String x:Key="UefiFallbackFirmwareFailedFormat">La préparation du démarrage firmware a échoué (rc={0}).</system:String>
    <system:String x:Key="UefiFallbackFirmwareReady">Démarrage firmware préparé. Redémarrez pour lancer le live.</system:String>
    <system:String x:Key="UefiFallbackPreparationFailed">La préparation du fallback a échoué.</system:String>
    <system:String x:Key="UefiFallbackRestoring">Restauration de l'état UEFI initial...</system:String>
    <system:String x:Key="UefiFallbackRestoreFailedFormat">La restauration UEFI a échoué (rc={0}).</system:String>
    <system:String x:Key="UefiFallbackWindowsRestored">Windows a été restauré. Libertix va se fermer.</system:String>
    <system:String x:Key="UefiFallbackCancelledLog">Transaction UEFI annulée et fichiers temporaires programmés pour suppression.</system:String>
    <system:String x:Key="UefiFallbackRestoreFailed">La restauration UEFI a échoué.</system:String>
    <system:String x:Key="UefiFallbackTimeoutLog">ERREUR : le processus de reprise a dépassé le délai de 30 minutes</system:String>

    <!-- Apply Changes -->
    <system:String x:Key="ApplyChangesTitle">Appliquer les modifications</system:String>
    <system:String x:Key="ApplyChangesWaiting">Pret a demarrer le partitionnement</system:String>
    <system:String x:Key="ApplyChangesSummary">Resume de l'installation</system:String>
    <system:String x:Key="ApplyChangesDistro">Distribution :</system:String>
    <system:String x:Key="ApplyChangesLinuxSize">Espace Linux :</system:String>
    <system:String x:Key="ApplyChangesUsername">Nom d'utilisateur :</system:String>
    <system:String x:Key="ApplyChangesStart">Demarrer l'installation</system:String>
    <system:String x:Key="ApplyChangesStep1">Reduction de la partition Windows pour Linux...</system:String>
    <system:String x:Key="ApplyChangesStep2">Creation de la partition FAT32 live/Linux (Z:)...</system:String>
    <system:String x:Key="ApplyChangesWaitDisk">Attente de la mise a jour du disque...</system:String>
    <system:String x:Key="ApplyChangesStep3">Reduction de la partition Windows pour Linux...</system:String>
    <system:String x:Key="ApplyChangesComplete">Partitionnement termine !</system:String>
    <system:String x:Key="ApplyChangesError">Une erreur s'est produite</system:String>
    <system:String x:Key="ApplyChangesReboot">Redemarrer</system:String>
    <system:String x:Key="ApplyChangesRebootConfirm">L'ordinateur va redemarrer pour terminer l'installation. Continuer ?</system:String>
    <system:String x:Key="PartitionSafetyBlockMessage">Installation bloquée jusqu'à résolution de ce contrôle de sécurité.</system:String>
</ResourceDictionary>
